# Copy this file to .env and fill in any values you want to override.

# Optional: send email alerts when high-scoring jobs appear
ALERT_EMAIL=you@example.com
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@example.com
SMTP_PASSWORD=your_app_password

# Optional: webhook alerts
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...

# Optional: customize alert threshold (0-100)
ALERT_THRESHOLD=60

# Optional: override default preferred tech stack (comma separated)
DEFAULT_PREFERRED_TECH=python,javascript,typescript,react,node.js,sql,docker,aws,azure,git,c#,java

# Optional: override default preferred locations (comma separated)
DEFAULT_PREFERRED_LOCATIONS=helsinki,espoo,vantaa,tampere,turku,oulu
